# Cerebras Gemma 4 (primary)
CEREBRAS_API_KEY=csk-your-key-here
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
GEMMA_MODEL=gemma-4-31b
# none | low | medium | high  (off = fastest; the whole pitch)
CEREBRAS_REASONING_EFFORT=none

# Optional GPU baseline for the side-by-side speed race (e.g. Gemini, Groq, OpenAI)
BASELINE_API_KEY=
BASELINE_BASE_URL=
BASELINE_MODEL=

# Optional: post the Coder/Builder/Reviewer build chatter to a Slack channel (incoming webhook URL).
# Leave blank to keep the team transcript in-app only (returned in /api/robotgame's "transcript").
SLACK_WEBHOOK_URL=
